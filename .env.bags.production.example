# DS箱包AI创作平台生产环境模板
# 只用于箱包站。不要复制服装站的 STORE_DATA_DIR / STORE_UPLOAD_DIR 到这里。

NODE_ENV=production
PORT=7777
APP_PUBLIC_BASE_URL=http://47.120.21.152:7777
NEXT_PUBLIC_APP_URL=http://47.120.21.152:7777

# 箱包站独立数据与上传目录
BAGS_STORE_DATA_DIR=/srv/depthshop-bags/data
BAGS_STORE_UPLOAD_DIR=/srv/depthshop-bags/uploads

# 箱包站管理员，二选一或都配置
ADMIN_PHONE_NUMBERS=
ADMIN_USER_IDS=

# 生图 API，正式环境建议使用箱包站独立 Key
YUNWU_API_KEY=
YUNWU_BASE_URL=https://yunwu.ai
YUNWU_IMAGE_MODEL=gpt-image-2
YUNWU_IMAGE_TIMEOUT_MS=600000

# 生视频 API，正式环境建议使用箱包站独立 Key
VIDEO_PROVIDER=ark
ARK_VIDEO_API_KEY=
ARK_VIDEO_BASE_URL=https://ark.cn-beijing.volces.com
ARK_VIDEO_MODEL=doubao-seedance-2-0-fast-260128
ARK_VIDEO_CREATE_PATH=/api/v3/contents/generations/tasks
ARK_VIDEO_STATUS_PATH=/api/v3/contents/generations/tasks/{id}
ARK_VIDEO_TIMEOUT_MS=120000
ARK_VIDEO_GENERATE_AUDIO=false
ARK_VIDEO_WATERMARK=false

# 视频高清输出 / 超分
VIDEO_UPSCALE_API_KEY=
VIDEO_UPSCALE_BASE_URL=https://mediakit.cn-beijing.volces.com
VIDEO_UPSCALE_CREATE_PATH=/api/v1/tools/enhance-video
VIDEO_UPSCALE_STATUS_PATH=/api/v1/tasks/{id}
VIDEO_UPSCALE_TIMEOUT_MS=120000
VIDEO_UPSCALE_CREDIT_TABLE_JSON=
VIDEO_UPSCALE_ALLOW_MISSING_PRICE=false

# 风格解析与视频提示词代写
STYLE_VISION_PROVIDER=openai_compatible
STYLE_VISION_API_KEY=
STYLE_VISION_BASE_URL=https://yunwu.ai
STYLE_VISION_MODEL=
VIDEO_PROMPT_WRITER_API_KEY=
VIDEO_PROMPT_WRITER_BASE_URL=https://yunwu.ai
VIDEO_PROMPT_WRITER_MODEL=gpt-4o-mini
VIDEO_PROMPT_WRITER_PRICE_TABLE_JSON={}

# 小服务器建议保持 1，避免影响同机其他服务
GENERATION_JOB_CONCURRENCY=1
